895d6962ce1b38cbf867f4a2ee58b8a4d9cba4abb1ea","copy":"Testing conducted by Apple in January and February 2026 using preproduction 16-inch MacBook{%nbsp%}Pro systems with :[Apple M5 Pro,]({%wj%}) 18{%nbhyp%}core CPU, 20{%nbhyp%}core GPU, 48GB of unified memory, and 1TB SSD. Wireless web battery life tested by browsing 25 popular websites while connected to Wi-Fi. Video streaming battery life tested with 1080p content in Safari while connected to Wi-Fi. Display brightness set to 8 clicks from the bottom and keyboard backlight was off. Battery life varies by use and configuration. See :[apple.com/batteries]({%url metadata=\"1\" destination-type=\"internal\"%}) for more information."},"r":{}},"1ca76f0f3a32d57ce7289bea60c4233a5602262caf8540ffff948888158e18e9":{"a":{"_model":"plain-text-copy","textType":"plainText","metadata":[],"_id":"1ca76f0f3a32d57ce7289bea60c4233a5602262caf8540ffff948888158e18e9","copy":"/batteries/"},"r":{}},"a918823c01ff126771e8d09e68dad766a67ad4d75f8f9178c4a3fcfc36bc669f":{"a":{"_model":"asset-set","alt":{"contentId":"1ccb54cb4e254d99947fc507b92a3ccb0ca601a8c1b864d539c4382175a30d23"},"viewportSmall":{"contentId":"319490a8fd831eb4a138188e22de667b204dabdead0ae8ef370523107fa3e56d"},"viewportMedium":{"contentId":"748a177924b935a8b4772acb33ccc99f44fdb5c41967bcfbce8286ae1754985d"},"viewportLarge":{"contentId":"036e1a68227019371bd7cb880f5383bd849fa18c2f47a305ba5d515b9be9e464"},"_id":"a918823c01ff126771e8d09e68dad766a67ad4d75f8f9178c4a3fcfc36bc669f"},"r":{"alt":true,"viewportSmall":true,"viewportMedium":true,"viewportLarge":true}},"1ccb54cb4e254d99947fc507b92a3ccb0ca601a8c1b864d539c4382175a30d23":{"a":{"_model":"plain-text-copy","textType":"plainText","metadata":[],"_id":"1ccb54cb4e254d99947fc507b92a3ccb0ca601a8c1b864d539c4382175a30d23","copy":"A person at an airport using their MacBook Pro","_meta":[]},"r":{}},"319490a8fd831eb4a138188e22de667b204dabdead0ae8ef370523107fa3e56d":{"a":{"_model":"pinnable-image","uri1x":"/assets-www/en_WW/mac/01_feature_card_b