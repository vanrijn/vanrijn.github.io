],"_id":"1ace42e942d953d230a02f7c2cf02eec4cbf3f2123234ed20e3cb0929c8b0805","copy":"When you choose to check out at Apple with Apple{%nbsp%}Card Monthly Installments.{%sosumi type=\"external\" metadata=\"1\"%}","_meta":[{"contentId":"250ac3177dc2f5f9d11db761e1ac01b7c5af10456fe310e1a66092265cc47f61"},{"contentId":"94c08ee30d2b3082401ae88a80e03f1f01bfd56a76c19b831ca2812f1841171d"},{"contentId":"96b62229a1705cf0f376e1aea533fb89c4d086cb6bd7cc24e884fcb01d3ce79e"},{"contentId":"c4f1688ac418d6f55590586382769e485f85b02d2570ee0d4bf4125ca17fc4a6"},{"contentId":"779e487f646b0b763e8afe49b062081d9792ee390982d507fa39d30126078117"},{"contentId":"1670df75c08ffa0d3e06a9c23af5b58518184a2a7fc8c3b2654e41474c474ff5"}]},"r":{"_meta":true}},"250ac3177dc2f5f9d11db761e1ac01b7c5af10456fe310e1a66092265cc47f61":{"a":{"_model":"markdown-inline-copy","textType":"markdown","categories":["legal"],"metadata":["94c08ee30d2b3082401ae88a80e03f1f01bfd56a76c19b831ca2812f1841171d","96b62229a1705cf0f376e1aea533fb89c4d086cb6bd7cc24e884fcb01d3ce79e","c4f1688ac418d6f55590586382769e485f85b02d2570ee0d4bf4125ca17fc4a6","779e487f646b0b763e8afe49b062081d9792ee390982d507fa39d30126078117","1670df75c08ffa0d3e06a9c23af5b58518184a2a7fc8c3b2654e41474c474ff5"],"_id":"250ac3177dc2f5f9d11db761e1ac01b7c5af10456fe310e1a66092265cc47f61","copy":"Apple{%nbsp%}Card Monthly Installments (ACMI) is a 0% APR payment option that is only available if you select it at checkout in the U.S. for eligible products purchased at Apple{%nbsp%}Store locations, :[apple.com]({%url metadata=\"1\" destination-type=\"internal\"%}), the Apple{%nbsp%}Store app, or by calling :[ :[1‑800‑MY‑APPLE]({%url metadata=\"2\" destination-type=\"external\"%})]({%wj%}), and is subject to credit approval and credit limit. See :[here]({%url metadata=\"3\" destination-type=\"appleExternal\"%}) for more information about eligible products. Existing customers: See your Customer Agreement for your variable APR. As of {%apr value=\"effectiveDate\"%}, the variable APR on new Apple{%nbsp%}Card accounts ranges from {%apr value=\"rates\"%}. You must elect to use ACMI at checkout. If you buy an ACMI‑eligible product with a one-time payment on Apple{%nbsp%}Card at checkout, that purchase is subject to your Apple{%nbsp%}Card’s variable APR, not the ACMI 0% APR. Taxes and shipping on items purchased using ACMI are subject to your Apple{%nbsp%}Card’s variable APR, not the ACMI 0% APR. In order to buy an iPhone with ACMI, you must select one of the following carriers (prepaid carrier plans are not supported): AT\u0026T, Boost Mobile, T‑Mobile, or Verizon. An iPhone purchased with ACMI is always unlocked, so you can switch carriers at any time, subject to your carrier’s terms. ACMI is not available for purchases made at the following special storefronts or when using these discounts in-store at Apple: Apple Employee Purchase Plan; participating corporate Employee Purchase Programs; Apple at Work for small businesses; Government and Veterans and Military Purchase Programs; or on refurbished devices. The last month’s payment for each product will be the product’s purchase price, less all other payments at the monthly payment amount. ACMI is subject to change at any time for any reason, including but not limited to installment term lengths and eligible products. See the :[Apple{%nbsp%}Card Customer Agreement]({%url metadata=\"4\" destination-type=\"external\"%}) for more information about ACMI.{%br%}{%br%}To access and use all Apple{%nbsp%}Card features and products available only to Apple{%nbsp%}Card users, you must add Apple{%nbsp%}Card to Wallet on an iPhone or iPad that supports and has the latest version of iOS or iPadOS. Apple{%nbsp%}Card is subject to credit approval, available only for qualifying applicants in the United States, and issued by Goldman Sachs Bank USA, Salt Lake City Branch.{%br%}{%br%}Apple Payments Services{%nbsp%}LLC, a subsidiary of Apple{%nbsp%}Inc., is a service provider of Goldman Sachs Bank USA for Apple{%nbsp%}Card and Savings accounts. Neither Apple{%nbsp%}Inc. nor Apple Payments Services{%nbsp%}LLC is a{%nbsp%}bank.{%br%}{%br%}All communications from Apple and Goldman Sachs Bank USA about Apple{%nbsp%}Card (including transactional and marketing communications) and customer service support are available in English. Certain communications about Apple{%nbsp%}Card can be viewed in another language depending on your device language settings. If you reside in the U.S. Virgin Islands, American Samoa, Guam, Northern Mariana Islands, or U.S. Minor Outlying Islands, please call Goldman Sachs at :[ :[877-255-5923]({%url metadata=\"5\" destination-type=\"external\"%})]({%wj%}) with questions about Apple{%nbsp%}Card.{%br%}{%br%}"},"r":{}},"94c08ee30d2b3082401ae88a80e03f1f01bfd56a76c19b831ca2812f1841171d":{"a":{"_model":"plain-text-copy","textType":"plainText","metadata":[],"_id":"94c08ee30d2b3082401ae88a80e03f1f01bfd56a76c19b831ca2812f1841171d","copy":"/"},"r":{}},"96b62229a1705cf0f376e1aea533fb89c4d086cb6bd7cc24e884fcb01d3ce79e":{"a":{"_model":"plain-text-copy","textType":"plainText","metadata":[],"_id":"96b62229a1705cf0f376e1aea533fb89c4d086cb6bd7cc24e884fcb01d3ce79e","copy":"tel:1-800-692-7753"},"r":{}},"c4f1688ac418d6f55590586382769e485f85b02d2570ee0d4bf4125ca17fc4a6":{"a":{"_model":"plain-text-copy","textType":"plainText","metadata":[],"_id":"c4f1688ac418d6f55590586382769e485f85b02d2570ee0d4bf4125ca17fc4a6","copy":"https://support.apple.com/102730"},"r":{}},"1670df75c08ffa0d3e06a9c23af5b58518184a2a7fc8c3b2654e41474c474ff5":{"a":{"_model":"plain-text-copy","textType":"plainText","metadata":[],"_id":"1670df75c08ffa0d3e06a9c23af5b58518184a2a7fc8c3b2654e41474c474ff5","copy":"tel:1-877-255-5923"},"r":{}},"cd61a95704e6b6475d5992fb56848d983cb17273e31c060fa8ab3df1993598e7":{"a":{"_model":"action-handler","action":"open","accessibilityText":{"contentId":"0261287272fc778a54e60c48522e3d61e91dd4bd238e487487d4ce9effe7fdc7"},"analyticsAttributes":[{"contentId":"aa8825994790b5bbb4bbbccb8e4f5186