) :[Vocal Shortcuts,]({%wj%}) and more, Mac has industry{%nbhyp%}leading built{%nbhyp%}in accessibility features that help you connect, create, and do what you love — in the ways that work :[best for you.]({%wj%})","_meta":[]},"r":{}},"7868d147cd72dc1846fffd64c6e51ba09d02c8823ec57e3ae4435fcf84df169b":{"a":{"_model":"asset-set","alt":{"contentId":"2b1bfdbd765b01fccc7d73df514584da2cf7556bb9ac3fdfd06a858cbcc656df"},"viewportSmall":{"contentId":"974ce923ba4fce25c64f2d1daf2304bbb187fbc14ea21dc66bc53b5693e8f5b9"},"viewportMedium":{"contentId":"a772ece3c9065b3d92275cfc86a069c588ce53cf5cb953e29ea26d086e69c009"},"viewportLarge":{"contentId":"d6d6d4a17081746edb46c28a3554f9dad64441bf99ffffda8a57b55832af9c44"},"_id":"7868d147cd72dc1846fffd64c6e51ba09d02c8823ec57e3ae4435fcf84df169b"},"r":{"alt":true,"viewportSmall":true,"viewportMedium":true,"viewportLarge":true}},"2b1bfdbd765b01fccc7d73df514584da2cf7556bb9ac3fdfd06a858cbcc656df":{"a":{"_model":"plain-text-copy","textType":"plainText","metadata":[],"_id":"2b1bfdbd765b01fccc7d73df514584da2cf7556bb9ac3fdfd06a858cbcc656df","copy":"macOS and iOS accessibility and system shortcuts icons","_meta":[]},"r":{}},"974ce923ba4fce25c64f2d1daf2304bbb187fbc14ea21dc66bc53b5693e8f5b9":{"a":{"_model":"pinnable-image","uri1x":"/assets-www/en_WW/mac/feature_card_boc/small/values_accessible_06911f69c.jpg","uri2x":"/assets-www/en_WW/mac/feature_card_boc/small/values_accessible_ebc41b4bf_2x.jpg","pinning":"center","_id":"974ce923ba4fce25c64f2d1daf2304bbb187fbc14ea21dc66bc53b5693e8f5b9","width1x":420,"height1x":255,"width2x":840,"height2x":510},"r":{}},"a772ece3c9065b3d92275cfc86a069c588ce53cf5cb953e29ea26d086e69c009":{"a":{"_model":"pinnable-image","uri1x":"/assets-www/en_WW/mac/feature_card_boc/medium/values_accessible_aa7270ba5.jpg","uri2x":"/assets-www/en_WW/mac/feature_card_boc/medium/values_accessible_a97b3b670_2x.jpg","pinning":"center","_id":"a772ece3c9065b3d92275cfc86a069c588ce53cf5cb953e29ea26d086e69c009","width1x":782,"height1x":423,"width2x