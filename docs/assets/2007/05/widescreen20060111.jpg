","metadata":[],"_id":"db3975c66384e55889295d48388c1bff2a69aee81b7889b484141a90b019b046","copy":"Good for you. Good for the planet.","_meta":[]},"r":{}},"56c6ef16f4889e47260f53c91d17e85a182a49700767d1cb9778e3d4de57fb4d":{"a":{"_model":"markdown-inline-copy","textType":"markdown","metadata":["53e78ae190b2db1b784b98a892fda0f4b7f327307a901670e24b011125df07e4"],"_id":"56c6ef16f4889e47260f53c91d17e85a182a49700767d1cb9778e3d4de57fb4d","copy":"With Apple{%nbsp%}Trade{%nbsp%}In, you can get a great value for your current device and apply it toward a new one. If your device isn’t eligible for credit, we’ll recycle it for{%nbsp%}free.{%sosumi type=\"numbered\" metadata=\"1\"%}","_meta":[{"contentId":"53e78ae190b2db1b784b98a892fda0f4b7f327307a901670e24b011125df07e4"}]},"r":{"_meta":true}},"53e78ae190b2db1b784b98a892fda0f4b7f327307a901670e24b011125df07e4":{"a":{"_model":"markdown-inline-copy","textType":"markdown","categories":["legal"],"metadata":[],"_id":"53e78ae190b2db1b784b98a892fda0f4b7f327307a901670e24b011125df07e4","copy":"Trade-in values will vary based on the condition, year, and configuration of your eligible trade-in device. Not all devices are eligible for credit. You must be at least the age of majority to be eligible to trade in for credit or for an Apple{%nbsp%}Gift{%nbsp%}Card. Trade-in value may be applied toward qualifying new device purchase, or added to an Apple{%nbsp%}Gift{%nbsp%}Card. Actual value awarded is based on receipt of a qualifying device matching the description provided when estimate was made. Sales tax may be assessed on full value of a new device purchase. In-store trade-in requires presentation of a valid photo ID (local law may require saving this information). Offer may not be available in all stores, and may vary between in-store and online trade-in. Some stores may have additional requirements. Apple or its trade-in partners reserve the right to refuse, cancel, or limit quantity of any trade-in transaction for any reason. More details are available from Apple’s trade-in partner for trade-in and recycling of eligible devices. Restrictions and limitations may apply."},"r":{}},"5dbadf48f00adb7826fb5e810e788fefdd205438ff69568410d90c9d954a0591":{"a":{"_model":"asset-set","alt":{"contentId":"dabc65ca758cea6d1b2083195c0e0d7ea6de2f947dd88b6c57da8e6a00ae3220"},"viewportSmall":{"contentId":"8319e82c200a762519e120571563d4f3c65fb6a0180ed1816adc1b546243e8ba"},"viewportMedium":{"contentId":"7b77d2c4d9d807f5b82383aac67c4cfb389f185e34c2cd6baa043cdcc6092da2"},"viewportLarge":{"contentId":"80973234ffd2edd1834f47698962cdd73d5649ae2a8015e499e03823790a602e"},"_id":"5dbadf48f00adb7826fb5e810e788fefdd205438ff69568410d90c9d954a0591"},"r":{"alt":true,"viewportSmall":true,"viewportMedium":true,"viewportLarge":true}},"dabc65ca758cea6d1b2083195c0e0d7ea6de2f947dd88b6c57da8e6a00ae3220":{"a":{"_model":"plain-text-copy","textType":"plainText","metadata":[],"_id":"dabc65ca758cea6d1b2083195c0e0d7ea6de2f947dd88b6c57da8e6a00ae3220","copy":"Two open silver Mac laptops, one turned to the side to show ports, the other viewed from overhead to partially show the keyboard.","_meta":[]},"r":{}},"8319e82c200a762519e120571563d4f3c65fb6a0180ed1816adc1b546243e8ba":{"a":{"_model":"pinnable-image","uri1x":"/assets-www/en_WW/mac/03_feature_card_boc/small/values_planet_4f12b7744.jpg","uri2x":"/assets-www/en_WW/mac/03_feature_card_boc/small/values_planet_007b172c0_2x.jpg","pinning":"center","_id":"8319e82c200a762519e120571563d4f3c65fb6a0180ed1816adc1b546243e8ba","width1x":420,"height1x":272,"width2x":840,"height2x":544},"r":{}},"7b77d2c4d9d807f5b82383aac67c4cfb389f185e34c2cd6baa043cdcc6092da2":{"a":{"_model":"pinnable-image","uri1x":"/assets-www/en_WW/mac/03_feature_card_boc/medium/values_planet_ac76d2b7f.jpg","uri2x":"/assets-www/en_WW/mac/03_feature_card_boc/medium/values_planet_7dcdfc2f7_2x.jpg","pinning":"center","_id":"7b77d2c4d9d807f5b82383aac67c4cfb389f185e34c2cd6baa043cdcc6092da2","width1x":782,"height1x":408,"width2x":1564,"height2x":816},"r