fd5c2d4bc3bbea4c091a78af92b639e22fdd8d0580dfc158e3d608d56adff","copy":"Use your iPhone from your Mac.","_meta":[]},"r":{}},"d34b1db7e8cc0f1e8afc9269021aba99462007b0dd012af3f63fe5aee1abfe85":{"a":{"_model":"markdown-inline-copy","textType":"markdown","metadata":["b35f7d2735826107de292629a8997613aad809055a0cdb1413dc3f0e41cab31b"],"_id":"d34b1db7e8cc0f1e8afc9269021aba99462007b0dd012af3f63fe5aee1abfe85","copy":"iPhone{%nbsp%}Mirroring lets you see and use what’s on your iPhone while using your Mac.{%sosumi type=\"numbered\" metadata=\"1\"%} And now Live{%nbsp%}Activities from iPhone also appear on your Mac. So you don’t have to reach for your phone to stay in the know.","_meta":[{"contentId":"b35f7d2735826107de292629a8997613aad809055a0cdb1413dc3f0e41cab31b"}]},"r":{"_meta":true}},"b35f7d2735826107de292629a8997613aad809055a0cdb1413dc3f0e41cab31b":{"a":{"_model":"markdown-inline-copy","textType":"markdown","categories":["legal"],"metadata":[],"_id":"b35f7d2735826107de292629a8997613aad809055a0cdb1413dc3f0e41cab31b","copy":"Available on Mac computers with Apple{%nbsp%}silicon and Intel-based Mac computers with a T2 Security Chip. Requires that your iPhone and Mac are signed in with the same :[Apple Account]({%wj%}) using two-factor authentication, your iPhone and Mac are near each other and have Bluetooth and Wi-Fi turned on, and your Mac is not using AirPlay or Sidecar. Some iPhone features (e.g., camera and microphone) are not compatible with iPhone{%nbsp%}Mirroring."},"r":{}},"e0f0b2493997c08be183ab4c104d5165983b3fc715586dec297a1f1792e48144":{"a":{"_model":"asset-set","alt":{"contentId":"bae998c99da9e7b69cd05eed5c48e50e0535c6a176e59606020c2864d7af24dc"},"viewportSmall":{"contentId":"95945b9080195534b7c4593b99e33f7b6f5f87a2c96b8ec6a11f155533f3ba95"},"viewportMedium":{"contentId":"9def1ecaf09d396eab6b4ab286951d6e56ac179c943011da7dc3ab4e280ab19b"},"viewportLarge":{"contentId":"70c21a30567bb20d884f4ddaad1c597d3b0c049e39be8d46e138472367981af5"},"_id":"e0f0b2493997c08be183ab4c