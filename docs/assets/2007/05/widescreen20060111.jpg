yle="--vp-w-large:715;--vp-h-large:480;--vp-w-medium:509;--vp-h-medium:355;--vp-w-small:320;--vp-h-small:236;--vp-w-default:715;--vp-h-default:480;--rp-op-large:center left;--rp-op-medium:center;--rp-op-small:center;--rp-op-default:center left;--rp-of-default:none" class="ResponsivePicture_responsive-picture__VWL7l ResponsivePicture_responsive-picture-vp-layout-default--sized__pdVra responsive-picture__no-js ResponsivePicture_responsive-picture--no-load___9Rzr ResponsivePicture_responsive-picture--removed__vyAL_ BannerCard_inlineImage__YYR9d"><picture class="ResponsivePicture_responsive-picture__picture__jjeBP ResponsivePicture_responsive-picture__picture__js__PPGS5"><source srcSet="#, # 2x" width="320" height="236" media="(max-width: 734px)"/><source srcSet="#, # 2x" width="509" height="355" media="(max-width: 1068px)"/><source srcSet="#, # 2x" width="715" height="480"/><img alt="Mac Studio, MacBook Pro, and iMac grouped together with screens facing forward."/></picture><noscript><picture class="ResponsivePicture_responsive-picture__picture__jjeBP ResponsivePicture_responsive-picture__picture__no-js__Ma_sk"><source srcSet="/assets-www/en_WW/mac/banner_card_1up/small/help_me_choose_82d665cfd.png, /assets-www/en_WW/mac/banner_card_1up/small/help_me_choose_847450e0f_2x.png 2x" width="320" height="236" media="(max-width: 734px)"/><source srcSet="/assets-www/en_WW/mac/banner_card_1up/medium/help_me_choose_f4ddb6763.png, /assets-www/en_WW/mac/banner_card_1up/medium/help_me_choose_bac9d63c0_2x.png 2x" width="509" height="355" media="(max-width: 1068px)"/><source srcSet="/assets-www/en_WW/mac/banner_card_1up/large/help_me_choose_52774d1af.png, /assets-www/en_WW/mac/banner_card_1up/large/help_me_choose_1627cced6_2x.png 2x" width="715" height="480"/><img alt="Mac Studio, MacBook Pro, and iMac grouped together with screens facing forward."/></picture></noscript></figure></div></div></div></div></section><section class="MarcomSection_section__Hd6T8 MarcomSection_backgroundTertiary___LAi8" data-analytics-section-engagement="name:switch to mac gallery"><div class="section-content"><div class="SectionHeader_container__OMsxL responsive-content_responsiveContent__S1ntz"><h2 id="banner-card-section-9-header" class="SectionHeader_headline__aqRKz MarcomSection_enhanced--inactive__Rs5JM"><span>Switch to Mac.</span></h2></div><div class="responsive-content_responsiveContent__S1ntz BannerCardSection_responsiveContainer__EoB1m"><div class="StaggeredFadeIn_animationWrapper__jM6PI StaggeredFadeIn_enhanced--inactive__vzETS animationDefaults_noBuildIn__wAp_w animationDefaults_buildIn__OdEKA"><div style="background-color:#FFFFFF" class="BannerCard_bannerCard__xHrOV BannerCard_twoUp__3pVcb BannerCard_cardVertical__wV5a2 BannerCard_copyLockupPinTop__UGz_4 BannerCard_inlineLayout__VaIgt BannerCard_backgroundColorAlt__2b0z_ BannerCard_blockLink__IlVL7 BaseCard_baseCard__9OdJ1"><a data-analytics-title="see what your device is worth" aria-hidden="true" class="OptionalBlockLink_blockLink__3DW3e" href="/us/shop/goto/trade_in#mac" tabindex="-1"></a><div class="BannerCard_copyLockup__9uRdS CopyLockup_textAlignCenter__7B4Wl"><div class="CopyLockup_headingContainer__eAcNT"><h3 class="CopyLockup_header__BZWbY"><span>Give us the old. <span aria-hidden="true" class="vbr ViewportBreakPoint_vbr--s__3RnsT"></span><span aria-hidden="true" class="vbr ViewportBreakPoint_vbr--m__uOal1"></span>Save on the new.</span></h3></div><p class="CopyLockup_copy__t5rPE"><span>With Apple Trade In, you can get a great value for your current device and apply it toward a new one. If your device isn’t eligible for credit, we’ll recycle it for free.<sup class="footnote Footnote_footnote__tg6qi Footnote_footnote-numbered__K0q48 "><a aria-label="Footnote 9" href="#footnote-numbered-9">9</a></sup></span></p><div class="OptionalCTABlock_ctaBlock__k2dm5 OptionalCTABlock_alignCenter__bgIt_ OptionalCTABlock_ctaInline__vG_6y"><a class="typography_bodyCopy__v_XbA OptionalCTABlock_link__pk9oy Standards