source "https://rubygems.org"

gem "jekyll", "~> 4.3"

group :jekyll_plugins do
  gem "jekyll-remote-theme"
  gem "jekyll-feed"
  gem "jekyll-include-cache"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-paginate-v2"
  # Required because jekyll-theme-basically-basic's gemspec lists it as a
  # dependency. Not enabled in _config.yml plugins list — pagination is
  # handled by jekyll-paginate-v2.
  gem "jekyll-paginate"
end

# Ruby 3+ no longer bundles webrick, but `jekyll serve` needs it
gem "webrick"



